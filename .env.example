# TDAI MCP Server Configuration
# ==============================

# --- Backend mode ------------------------------------------------
# "gateway" (default) — starts the original Node.js TDAI Gateway
#                       as a subprocess and forwards via HTTP.
# "direct"            — reads/writes SQLite directly (no Node.js).
TDAI_BACKEND=gateway

# --- Data directory ----------------------------------------------
# Path to the TencentDB-Agent-Memory data directory.
# Default: ~/.openclaw/memory-tdai/  (OpenClaw plugin layout)
#          ~/.memory-tencentdb/       (Standalone Gateway layout)
TDAI_DATA_DIR=

# --- LLM service (for L1/L2/L3 extraction) ----------------------
# Compatible with any OpenAI-compatible API.
# Required for persona generation & memory extraction.
# Tencent Cloud LKE endpoint shown below.
LLM_API_KEY=
LLM_BASE_URL=https://api.lkeap.cloud.tencent.com/v1
LLM_MODEL=deepseek-v3.2

# Gateway LLM config (env vars passed to the subprocess)
TDAI_LLM_API_KEY=
TDAI_LLM_BASE_URL=
TDAI_LLM_MODEL=
TDAI_LLM_MAX_TOKENS=4096
TDAI_LLM_TIMEOUT_MS=120000

# --- MCP transport (stdio or sse) --------------------------------
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8421

# --- Gateway network ---------------------------------------------
TDAI_GATEWAY_PORT=8420
TDAI_GATEWAY_HOST=127.0.0.1
